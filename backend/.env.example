# Database (required for testing; Azure: set in App Service Application settings)
DB_NAME=rock_access
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
# Azure production: DB_HOST, DB_NAME, DB_USER, DB_PASSWORD (and optionally DB_PORT) from App Service config

# Django (required in production)
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# CORS: default allows localhost:3000, 127.0.0.1:3000, 192.168.176.1:3000, etc. Add more if needed:
# CORS_EXTRA_ORIGINS=http://192.168.1.5:3000

# Microsoft (Azure AD) sign-in for HASC single-tenant
# Set these to enable "Sign in with Microsoft"; redirect goes to FRONTEND_URL/login/callback
# AZURE_AD_TENANT_ID=your-hasc-tenant-guid
# AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# FRONTEND_URL=http://localhost:3000
# Optional: set to True to disable email+password login (Microsoft only)
# ONLY_MICROSOFT_LOGIN=False

# Optional: KMS for encryption (local | azure | aws | gcp). See COMPLETION_GUIDE.md §1.
# KMS_PROVIDER=local
# ENCRYPTION_KEY=  # required when KMS_PROVIDER=local; use strong key in production

# Azure Key Vault (when KMS_PROVIDER=azure)
# AZURE_KEY_VAULT_URL=
# AZURE_KEY_NAME=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# AWS KMS (when KMS_PROVIDER=aws)
# AWS_KMS_KEY_ID=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# GCP KMS (when KMS_PROVIDER=gcp)
# GCP_PROJECT_ID=
# GCP_LOCATION=us-east1
# GCP_KEY_RING=
# GCP_KEY_NAME=
# GCP_CREDENTIALS_PATH=/path/to/service-account.json
